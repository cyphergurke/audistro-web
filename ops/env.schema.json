{
  "service": "audistro-web",
  "keys": [
    { "key": "AUDISTRO_ENV", "required_in_prod": true, "pattern": "^(prod|dev|test)$", "redact": false },
    { "key": "CATALOG_BASE_URLS", "required_in_prod": true, "pattern": "^https?://[^\\s,]+(,https?://[^\\s,]+)*$", "redact": false },
    { "key": "FAP_BASE_URL", "required_in_prod": true, "pattern": "^https?://[^\\s]+$", "redact": false },
    { "key": "NEXT_PUBLIC_FAP_PUBLIC_BASE_URL", "required_in_prod": true, "pattern": "^https?://[^\\s]+$", "redact": false }
  ]
}
